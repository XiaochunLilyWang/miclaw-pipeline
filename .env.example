# miclaw 舆情分析流水线 — 环境变量配置
# 复制本文件为 .env 并填入实际值，.env 不要提交到 git

# ── Gemini / OpenAI 兼容接口 ──────────────────────────
# API Key（必填）
MICLAW_GEMINI_API_KEY=your_api_key_here

# API Base URL（选填，默认 OpenAI 官方；如使用代理或其他模型服务商请修改）
MICLAW_GEMINI_BASE_URL=https://api.openai.com/v1/

# 使用的模型名（选填，默认 gpt-4o）
# 支持多模态（图片/视频）的模型，推荐：
#   gpt-4o                           （OpenAI 官方）
#   vertex_ai/gemini-3-flash-preview （Google Vertex AI 代理）
MICLAW_GEMINI_MODEL=gpt-4o
